    {
      "parameters": {
        "jsCode": "const data = $json;\n\nreturn [\n  {\n    json: {\n      etsy_title: data.etsy_title || '',\n      short_description: data.short_description || '',\n      full_description: data.full_description || '',\n      seo_keywords: Array.isArray(data.seo_keywords) ? data.seo_keywords.join(', ') : data.seo_keywords || '',\n      tags: Array.isArray(data.tags) ? data.tags.join(', ') : data.tags || '',\n      target_audience: data.target_audience || '',\n      benefits: Array.isArray(data.benefits) ? data.benefits.join('\\n') : data.benefits || '',\n      mockup_ideas: Array.isArray(data.mockup_ideas) ? data.mockup_ideas.join('\\n') : data.mockup_ideas || '',\n      faq: Array.isArray(data.faq) ? JSON.stringify(data.faq) : data.faq || '',\n      cta: data.cta || ''\n    }\n  }\n];"
      },
