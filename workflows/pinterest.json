    {
      "parameters": {
        "jsCode": "const coreContext = $items(\"Get Core Brand Context\")[0].json.Content;\nconst outputRules = $items(\"Get Core Output Rules\")[0].json.Content;\nconst platformPrompt = $items(\"Get Pinterest Prompt\")[0].json.Content;\nconst productPrompt = $items(\"Get Product Prompt\")[0].json.Content;\nconst brand = $items(\"Get Brand Profile\")[0].json;\n\nconst finalPrompt = `\n${coreContext}\n\n${outputRules}\n\n${platformPrompt}\n\n${productPrompt}\n\nBrand: ${brand.Brand}\nProduct: ${brand.Product}\nNiche: ${brand.Niche}\nAudience: ${brand.Audience}\nStyle: ${brand.Style}\nColors: ${brand.Colors}\nTone: ${brand.Tone}\nLanguage: ${brand.Language}\nMarket: ${brand.Market}\nGoal: ${brand.Goal}\n\nGenerate HIGH CTR Pinterest content optimized for:\n- saves\n- clicks\n- Etsy traffic\n- emotional hooks\n- Pinterest SEO\n\nReturn ONLY valid JSON using this structure:\n\n{\n  \"pin_title\":\"\",\n  \"pin_description\":\"\",\n  \"hook\":\"\",\n  \"cta\":\"\",\n  \"seo_keywords\":[],\n  \"text_overlay\":\"\",\n  \"pin_style\":\"\",\n  \"visual_direction\":\"\",\n  \"mockup_ideas\":[],\n  \"target_emotion\":\"\",\n  \"audience\":\"\",\n  \"hashtags\":[]\n}\n`;\n\nreturn [\n  {\n    json: {\n      prompt: finalPrompt\n    }\n  }\n];"
      },
