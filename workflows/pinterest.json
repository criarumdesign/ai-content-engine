    {
      "parameters": {
        "jsCode": "const data = $json;\n\nreturn [\n  {\n    json: {\n      pin_title: data.pin_title || '',\n      pin_description: data.pin_description || '',\n      hook: data.hook || '',\n      cta: data.cta || '',\n      seo_keywords: Array.isArray(data.seo_keywords)\n        ? data.seo_keywords.join(', ')\n        : data.seo_keywords || '',\n\n      text_overlay: data.text_overlay || '',\n      pin_style: data.pin_style || '',\n      visual_direction: data.visual_direction || '',\n\n      mockup_ideas: Array.isArray(data.mockup_ideas)\n        ? data.mockup_ideas.join('\\n')\n        : data.mockup_ideas || '',\n\n      target_emotion: data.target_emotion || '',\n      audience: data.audience || '',\n\n      hashtags: Array.isArray(data.hashtags)\n        ? data.hashtags.join(' ')\n        : data.hashtags || ''\n    }\n  }\n];"
      },
