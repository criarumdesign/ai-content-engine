        "jsCode": "const data = $json;\n\nreturn [\n  {\n    json: {\n      hook: data.hook || '',\n      caption: data.caption || '',\n      cta: data.cta || '',\n      carousel_idea: data.carousel_idea || '',\n      reel_idea: data.reel_idea || '',\n      story_idea: data.story_idea || '',\n      hashtags: Array.isArray(data.hashtags)\n        ? data.hashtags.join(' ')\n        : data.hashtags || '',\n      target_emotion: data.target_emotion || '',\n      audience: data.audience || '',\n      tone: data.tone || ''\n    }\n  }\n];"
