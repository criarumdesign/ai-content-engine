    {
      "parameters": {
        "jsCode": "const coreContext = $items(\"Get Core Brand Context\")[0].json.Content;\nconst outputRules = $items(\"Get Core Output Rules\")[0].json.Content;\nconst platformPrompt = $items(\"Get Instagram Prompt\")[0].json.Content;\nconst productPrompt = $items(\"Get Product Prompt\")[0].json.Content;\nconst brand = $items(\"Get Brand Profile\")[0].json;\n\nconst finalPrompt = `\n${coreContext}\n\n${outputRules}\n\n${platformPrompt}\n\n${productPrompt}\n\nBrand: ${brand.Brand}\nProduct: ${brand.Product}\nNiche: ${brand.Niche}\nAudience: ${brand.Audience}\nStyle: ${brand.Style}\nColors: ${brand.Colors}\nTone: ${brand.Tone}\nLanguage: ${brand.Language}\nMarket: ${brand.Market}\nGoal: ${brand.Goal}\n\nGenerate Instagram content optimized for:\n- engagement\n- saves\n- comments\n- brand trust\n- profile visits\n- Etsy traffic\n\nReturn ONLY valid JSON using this structure:\n\n{\n  \"hook\":\"\",\n  \"caption\":\"\",\n  \"cta\":\"\",\n  \"carousel_idea\":\"\",\n  \"reel_idea\":\"\",\n  \"story_idea\":\"\",\n  \"hashtags\":[],\n  \"target_emotion\":\"\",\n  \"audience\":\"\",\n  \"tone\":\"\"\n}\n`;\n\nreturn [\n  {\n    json: {\n      prompt: finalPrompt\n    }\n  }\n];"
      },
